{
  "identifier": "default",
  "description": "Default capabilities",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "http:default",
    "os:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/readest",
          "cmd": "bin/readest",
          "args": true
        }
      ]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" },
        { "url": "http://*:*/**" },
        { "url": "https://*:*/**" },
        { "url": "http://*/**" },
        { "url": "https://*/**" }
      ]
    }
  ]
}