{
  "identifier": "default",
  "description": "Default capabilities",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "http:default",
    "os:default",
    "shell:default",
    "opener:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" },
        { "url": "http://*:*/**" },
        { "url": "https://*:*/**" },
        { "url": "http://*/**" },
        { "url": "https://*/**" }
      ]
    }
  ]
}