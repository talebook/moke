{
  "name": "moke",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.tauri -- next dev --turbo",
    "build": "dotenv -e .env.tauri -- next build --turbo",
    "start": "dotenv -e .env.tauri -- next start",
    "dev-web": "dotenv -e .env.web -- next dev --turbo",
    "build-web": "dotenv -e .env.web -- next build --turbo",
    "tauri": "tauri",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:reader": "cd readest && pnpm --filter @readest/readest-app build",
    "dev:reader": "cd readest && pnpm --filter @readest/readest-app dev",
    "copy:reader": "node -e \"require('fs').cpSync('readest/out/readest','out/readest',{recursive:true})\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
